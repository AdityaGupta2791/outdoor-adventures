NODE_ENV=development
PORT=4000

# Database (Neon — get from neon.tech dashboard)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# Google OAuth (fill when building Auth module)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Razorpay (fill when building Payments module)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google Gemini (fill when building LLM module)
GEMINI_API_KEY=

# Cloudinary (fill when building Trip Catalog module)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
